# Server
ENV=dev
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173"]

# Database — local dev defaults match infra/docker/docker-compose.yml
# (host ports 15432/16379 avoid the Windows Hyper-V/WSL2 reserved port
# ranges and any local Postgres install on 5432).
DATABASE_URL=postgresql+asyncpg://poker:poker@localhost:15432/poker
REDIS_URL=redis://localhost:16379/0

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_TTL_SECONDS=86400

# X OAuth — register an app at https://developer.x.com/
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:5173/auth/callback

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5

# Game economy
PLAY_CHIP_GRANT=10000
DEFAULT_MIN_BUYIN_BB=50
DEFAULT_MAX_BUYIN_BB=200
ACTION_TIMER_SECONDS=25
TIMEBANK_SECONDS=30
DISCONNECT_GRACE_SECONDS=30
